# =============================================================================
# Infrastructure (wajib di .env — jangan pindah ke UI Config)
# =============================================================================
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Kosongkan untuk URL relatif /storage/... (disarankan di local).
# FILESYSTEM_PUBLIC_URL=https://cdn.example.com/storage

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

ADMIN_ROUTE_PREFIX=app
ADMIN_ROUTE_NAME=app
ADMIN_MENU_DOMAIN=app

# Kredensial superadmin saat seeding (WAJIB ganti di production)
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=password

# =============================================================================
# App behavior & integrasi (fallback deploy awal)
# Nilai utama diatur lewat menu Config superadmin (/app/config)
# =============================================================================

# Registrasi publik
REGISTRATION_ENABLED=true

# Role & domain email auto-provision peserta haji
HAJJ_PARTICIPANT_ROLE=user
HAJJ_PARTICIPANT_EMAIL_DOMAIN=peserta-haji.local

# Keamanan
IMPERSONATION_TIMEOUT_MINUTES=0
TWO_FACTOR_ENABLED=false
SECURITY_CSP_ENABLED=false

# Monitoring (opsional — butuh sentry/sentry-laravel)
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Google OAuth (fallback jika belum diisi di UI Config)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Email SMTP (fallback jika belum diisi di UI Config)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Provider mail tambahan (fallback)
POSTMARK_API_KEY=
RESEND_API_KEY=

# Notifikasi Slack (fallback)
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

# AI (fallback jika belum diisi di UI Config)
AI_PROVIDER=
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
